# LLM Balancer Configuration
# Copy this file to .env and configure your settings

# Port for the load balancer
LB_PORT=3001

# Comma-separated list of backend Ollama server URLs
# Each backend will be health checked and used in priority-based selection
OLLAMA_BACKENDS=http://host1:11434,http://host2:11434

# Health check interval in milliseconds (default: 30000)
HEALTH_CHECK_INTERVAL=30000

# Health check timeout in milliseconds (default: 5000)
HEALTH_CHECK_TIMEOUT=5000

# Maximum number of retries per request (default: 3)
MAX_RETRIES=3

# Maximum payload size in bytes (default: 50MB)
# Common values: 50MB (52428800), 100MB (104857600), 200MB (209715200)
MAX_PAYLOAD_SIZE=52428800

# Example configuration with multiple backends:
# OLLAMA_BACKENDS=http://host1:11434,http://host2:11434,http://host3:11434